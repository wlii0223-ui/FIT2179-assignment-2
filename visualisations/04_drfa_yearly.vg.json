{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 315,
  "title": {
    "text": "DRFA activations by year",
    "subtitle": "Local recovery activations increased sharply in several recent years."
  },
  "data": {"url": "../processed_data/drfa_yearly.csv"},
  "layer": [
    {
      "mark": {"type": "area", "color": "#d9b27c", "opacity": 0.32},
      "encoding": {
        "x": {"field": "year", "type": "ordinal", "title": null, "axis": {"labelAngle": 0, "labelOverlap": true}},
        "y": {"field": "activations", "type": "quantitative", "title": "Activations"}
      }
    },
    {
      "mark": {"type": "line", "color": "#9d351f", "strokeWidth": 3},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "activations", "type": "quantitative"}
      }
    },
    {
      "transform": [{"filter": "datum.year == 2011 || datum.year == 2016 || datum.year == 2021 || datum.year == 2022 || datum.year == 2025 || datum.year == 2026"}],
      "mark": {"type": "point", "filled": true, "size": 90, "color": "#1d2320"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "activations", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "activations", "type": "quantitative", "title": "Activations"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.year == 2011 || datum.year == 2016 || datum.year == 2022 || datum.year == 2025 || datum.year == 2026"},
        {"calculate": "datum.year == 2011 ? '2011' : datum.year == 2016 ? '2016' : datum.year == 2022 ? '2022 peak' : datum.year == 2025 ? '2025 high' : '2026 partial'", "as": "label"}
      ],
      "mark": {"type": "text", "align": "center", "dy": -12, "font": "Trebuchet MS", "fontSize": 13, "color": "#1d2320"},
      "encoding": {
        "x": {"field": "year", "type": "ordinal"},
        "y": {"field": "activations", "type": "quantitative"},
        "text": {"field": "label", "type": "nominal"}
      }
    }
  ],
  "config": {
    "background": null,
    "axis": {"labelFont": "Trebuchet MS", "titleFont": "Trebuchet MS", "gridColor": "#e7dfd2", "domain": false},
    "title": {"font": "Georgia", "fontSize": 17, "subtitleFont": "Trebuchet MS", "subtitleFontSize": 12, "anchor": "start"},
    "view": {"stroke": null}
  }
}
