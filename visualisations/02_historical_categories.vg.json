{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Historical event categories",
  "data": {"url": "../processed_data/historical_category_counts.csv"},
  "mark": {"type": "bar", "cornerRadiusEnd": 2},
  "encoding": {
    "x": {"field": "events", "type": "quantitative", "title": "Events"},
    "y": {"field": "category", "type": "nominal", "sort": "-x", "title": null},
    "color": {
      "field": "category",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": ["Flood", "Bushfire", "Severe Storm", "Cyclone", "Environmental", "Hail", "Earthquake", "Landslide", "Tornado"],
        "range": ["#246a8d", "#c85a2e", "#6c5f9f", "#5f7fa3", "#8a6335", "#d09a2d", "#5f5147", "#7f8fa1", "#5a788a"]
      }
    },
    "tooltip": [
      {"field": "category", "type": "nominal", "title": "Type"},
      {"field": "events", "type": "quantitative", "title": "Events"}
    ]
  },
  "config": {
    "background": null,
    "axis": {"labelFont": "Trebuchet MS", "titleFont": "Trebuchet MS", "gridColor": "#e7dfd2", "domain": false},
    "title": {"font": "Georgia", "fontSize": 17, "anchor": "start"},
    "view": {"stroke": null}
  }
}
