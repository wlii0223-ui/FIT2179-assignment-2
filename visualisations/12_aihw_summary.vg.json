{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 315,
  "title": {
    "text": "Forces of nature: who carries the burden?",
    "subtitle": "Dark segments show the selected group as a share of the reported total."
  },
  "data": {
    "values": [
      {"label": "Male hospitalisations", "row": "Hospitalisations", "group": "Male", "total": 815, "value": 552, "share": 67.7, "period": "2023-24"},
      {"label": "Age 65+ hospitalisations", "row": "Hospitalisations", "group": "Age 65+", "total": 815, "value": 299, "share": 36.7, "period": "2023-24"},
      {"label": "Male deaths", "row": "Deaths", "group": "Male", "total": 68, "value": 41, "share": 60.3, "period": "2022-23"}
    ]
  },
  "layer": [
    {
      "mark": {"type": "bar", "height": 28, "cornerRadius": 3, "color": "#ead8b9"},
      "encoding": {
        "x": {"field": "total", "type": "quantitative", "title": "Reported count"},
        "y": {
          "field": "label",
          "type": "nominal",
          "title": null,
          "sort": ["Male hospitalisations", "Age 65+ hospitalisations", "Male deaths"],
          "axis": {"labelLimit": 185}
        }
      }
    },
    {
      "mark": {"type": "bar", "height": 28, "cornerRadiusEnd": 3, "color": "#b9852b"},
      "encoding": {
        "x": {"field": "value", "type": "quantitative", "title": "Reported count"},
        "y": {
          "field": "label",
          "type": "nominal",
          "title": null,
          "sort": ["Male hospitalisations", "Age 65+ hospitalisations", "Male deaths"],
          "axis": {"labelLimit": 185}
        },
        "tooltip": [
          {"field": "row", "type": "nominal", "title": "Outcome"},
          {"field": "group", "type": "nominal", "title": "Group"},
          {"field": "period", "type": "nominal", "title": "Period"},
          {"field": "value", "type": "quantitative", "title": "Group count", "format": ","},
          {"field": "total", "type": "quantitative", "title": "Total", "format": ","},
          {"field": "share", "type": "quantitative", "title": "Share", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 8, "font": "Trebuchet MS", "fontSize": 15, "color": "#1d2320"},
      "encoding": {
        "x": {"field": "value", "type": "quantitative"},
        "y": {"field": "label", "type": "nominal", "sort": ["Male hospitalisations", "Age 65+ hospitalisations", "Male deaths"]},
        "text": {"expr": "format(datum.value, ',') + ' (' + format(datum.share, '.0f') + '%)'"}
      }
    }
  ],
  "config": {
    "background": null,
    "axis": {"labelFont": "Trebuchet MS", "titleFont": "Trebuchet MS", "gridColor": "#e7dfd2", "domain": false},
    "title": {"font": "Georgia", "fontSize": 17, "subtitleFont": "Trebuchet MS", "subtitleFontSize": 12, "anchor": "start"},
    "view": {"stroke": null}
  }
