{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": {
    "text": "High-impact historical events",
    "subtitle": "Short axis labels; hover for full event names."
  },
  "data": {"url": "../processed_data/historical_top_impact_events.csv"},
  "transform": [
    {"window": [{"op": "rank", "as": "rank"}], "sort": [{"field": "impact_score", "order": "descending"}]},
    {"filter": "datum.rank <= 8"},
    {
      "calculate": "datum.title == 'Cyclone Tracy' ? 'Cyclone Tracy' : datum.title == 'Bushfire - Ash Wednesday' ? 'Ash Wednesday' : datum.title == 'Bushfire - Black Saturday, Victoria 2009' ? 'Black Saturday' : datum.title == 'Flood - Hunter Valley' ? 'Hunter Valley flood' : datum.category == 'Environmental' && isValid(datum.year) ? 'Heatwave ' + datum.year : datum.title == 'Bushfire - Black Tuesday Tasmania' ? 'Black Tuesday' : datum.title == 'Flood - Brisbane River' ? 'Brisbane River flood' : datum.title",
      "as": "short_label"
    }
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 2, "color": "#8e3423"},
  "encoding": {
    "x": {"field": "impact_score", "type": "quantitative", "title": "Impact score"},
    "y": {"field": "short_label", "type": "nominal", "sort": "-x", "title": null, "axis": {"labelLimit": 240}},
    "tooltip": [
      {"field": "title", "type": "nominal", "title": "Event"},
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "deaths", "type": "quantitative", "title": "Deaths", "format": ","},
      {"field": "injuries", "type": "quantitative", "title": "Injuries", "format": ","},
      {"field": "impact_score", "type": "quantitative", "title": "Impact score", "format": ","}
    ]
  },
  "config": {
    "background": null,
    "axis": {"labelFont": "Trebuchet MS", "titleFont": "Trebuchet MS", "gridColor": "#e7dfd2", "domain": false},
    "title": {"font": "Georgia", "fontSize": 17, "anchor": "start"},
    "view": {"stroke": null}
  }
}
